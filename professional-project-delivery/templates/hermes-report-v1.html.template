<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{TITLE}}</title>
  <style>
    :root{--bg:#f7f4ee;--panel:#fffaf2;--text:#171717;--muted:#66604f;--line:#ded4c4;--accent:#1f5eff;--ok:#0a7a3d;--warn:#b46a00;--bad:#b42318;--chip:#eee6d8;--shadow:0 18px 50px rgba(31,24,10,.10)}
    *{box-sizing:border-box} body{margin:0;background:linear-gradient(180deg,#fbf8f1,var(--bg));color:var(--text);font:16px/1.55 ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Arial} a{color:var(--accent);text-decoration:none} a:hover{text-decoration:underline}
    .wrap{max-width:1180px;margin:0 auto;padding:24px}.hero{display:grid;grid-template-columns:1.4fr .8fr;gap:18px;margin-bottom:18px}.panel{background:var(--panel);border:1px solid var(--line);border-radius:22px;box-shadow:var(--shadow);padding:22px}.eyebrow{font-size:12px;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);font-weight:800} h1{font-size:clamp(30px,5vw,58px);line-height:.98;margin:10px 0} h2{font-size:24px;margin:0 0 12px} h3{font-size:18px;margin:20px 0 8px}.verdict{font-size:20px;font-weight:750;margin:14px 0}.meta{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px}.chip{display:inline-flex;align-items:center;gap:6px;background:var(--chip);border:1px solid var(--line);border-radius:999px;padding:6px 10px;font-size:13px;color:#2c281f}.chip.ok{background:#e6f4ec;color:var(--ok);border-color:#bfe5cd}.chip.warn{background:#fff3db;color:var(--warn);border-color:#ffd38a}.chip.bad{background:#fee4e2;color:var(--bad);border-color:#fecdca}.score{font-size:52px;line-height:1;font-weight:900}.score small{font-size:18px;color:var(--muted)}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}.kpi{padding:14px;border-radius:16px;background:#fff;border:1px solid var(--line)}.kpi b{display:block;font-size:25px}.tabs{display:flex;gap:8px;overflow:auto;padding:8px 0 14px;position:sticky;top:0;background:rgba(247,244,238,.94);backdrop-filter:blur(8px);z-index:5}.tab{border:1px solid var(--line);border-radius:999px;background:#fff;padding:9px 13px;cursor:pointer;white-space:nowrap;font-weight:750}.tab[aria-selected="true"]{background:#171717;color:#fff;border-color:#171717}.section{display:none}.section.active{display:block}.cards{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}.card{border:1px solid var(--line);border-radius:18px;background:#fff;padding:16px}.card .top{display:flex;justify-content:space-between;gap:10px;align-items:flex-start}.status{font-size:12px;font-weight:900;text-transform:uppercase;border-radius:999px;padding:4px 8px;background:var(--chip)}.status.pass{background:#e6f4ec;color:var(--ok)}.status.fail{background:#fee4e2;color:var(--bad)}.status.blocked{background:#fff3db;color:var(--warn)}.muted{color:var(--muted)} pre{white-space:pre-wrap;overflow:auto;background:#161616;color:#f4f4f4;border-radius:14px;padding:14px;font-size:13px} code{background:#eee6d8;border-radius:6px;padding:2px 5px}.filter{width:100%;padding:12px;border:1px solid var(--line);border-radius:14px;margin:0 0 14px;background:#fff}.list{display:grid;gap:10px}.row{border:1px solid var(--line);border-radius:14px;background:#fff;padding:12px}.artifact{display:grid;grid-template-columns:1.2fr .5fr .5fr .7fr;gap:8px;align-items:center}.footer{color:var(--muted);font-size:13px;margin:24px 0}.empty{padding:18px;border:1px dashed var(--line);border-radius:16px;color:var(--muted);background:#fff}
    @media(max-width:800px){.wrap{padding:14px}.hero,.cards,.grid{grid-template-columns:1fr}.panel{padding:16px;border-radius:18px}.artifact{grid-template-columns:1fr}.score{font-size:42px}.tabs{margin-left:-14px;margin-right:-14px;padding-left:14px}}
    @media print{.tabs{position:static}.section{display:block}.tab{display:none}.panel{box-shadow:none}}
  </style>
</head>
<body>
  <main class="wrap">
    <section class="hero">
      <div class="panel">
        <div class="eyebrow">{{SCOPE}} · {{DATE}}</div>
        <h1>{{TITLE}}</h1>
        <p class="verdict">{{VERDICT}}</p>
        <div class="meta">{{BADGES}}</div>
      </div>
      <aside class="panel">
        <div class="eyebrow">Score décisionnel</div>
        <div class="score">{{SCORE}}<small>/100</small></div>
        <p class="muted">{{SCORE_LABEL}}</p>
        <div class="grid">{{KPI_CARDS}}</div>
      </aside>
    </section>
    <nav class="tabs" role="tablist" aria-label="Sections du rapport">
      <button class="tab" role="tab" aria-selected="true" data-tab="resume">Résumé</button>
      <button class="tab" role="tab" aria-selected="false" data-tab="evidence">Evidence</button>
      <button class="tab" role="tab" aria-selected="false" data-tab="output">Output</button>
      <button class="tab" role="tab" aria-selected="false" data-tab="benchmark">Benchmark</button>
      <button class="tab" role="tab" aria-selected="false" data-tab="sources">Sources</button>
      <button class="tab" role="tab" aria-selected="false" data-tab="failures">Failures</button>
      <button class="tab" role="tab" aria-selected="false" data-tab="next">Next</button>
    </nav>
    <section id="resume" class="section active panel">{{RESUME_HTML}}</section>
    <section id="evidence" class="section panel">{{EVIDENCE_HTML}}</section>
    <section id="output" class="section panel">{{OUTPUT_HTML}}</section>
    <section id="benchmark" class="section panel">{{BENCHMARK_HTML}}</section>
    <section id="sources" class="section panel">{{SOURCES_HTML}}</section>
    <section id="failures" class="section panel">{{FAILURES_HTML}}</section>
    <section id="next" class="section panel">{{NEXT_HTML}}</section>
    <p class="footer">Generated by Hermes Report V1. Source map: <code>{{SOURCE_MAP_PATH}}</code>. QA: <code>{{QA_PATH}}</code>.</p>
  </main>
  <script>
    const tabs=[...document.querySelectorAll('.tab')];
    const sections=[...document.querySelectorAll('.section')];
    function activate(id){tabs.forEach(t=>t.setAttribute('aria-selected', String(t.dataset.tab===id)));sections.forEach(s=>s.classList.toggle('active', s.id===id)); if(location.hash.slice(1)!==id) history.replaceState(null,'','#'+id)}
    tabs.forEach(t=>t.addEventListener('click',()=>activate(t.dataset.tab)));
    if(location.hash && document.getElementById(location.hash.slice(1))) activate(location.hash.slice(1));
    document.querySelectorAll('[data-filter]').forEach(input=>{input.addEventListener('input',()=>{const q=input.value.toLowerCase();document.querySelectorAll(input.dataset.filter).forEach(el=>{el.style.display=el.textContent.toLowerCase().includes(q)?'':'none'})})});
  </script>
</body>
</html>
