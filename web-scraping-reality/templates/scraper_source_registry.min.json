{
  "version": 1,
  "defaults": {
    "artifact_root": "/opt/data/artifacts/scraper-smoke-runs",
    "tailscale_socks": "socks5://127.0.0.1:1055",
    "timeout_seconds": 120,
    "max_concurrency": 2
  },
  "sources": [
    {
      "id": "example_source",
      "project": "vertical-name",
      "label": "Human-readable smoke label",
      "priority": 10,
      "method": "api_direct|browser_network_capture|rss_html_dry_run|db_report|local_watchdog",
      "proxy_policy": "direct|never|tailscale_mobile|self_check|auto_script_default",
      "enabled": true,
      "quick": true,
      "timeout_seconds": 90,
      "command": ["python3", "/opt/data/scripts/example_scraper.py", "--dry-run"],
      "success_json_paths": ["offers", "events", "by_source"],
      "classification_rules": {
        "ok_with_items": "prod-candidate",
        "ok_no_items": "needs-hardening",
        "blocked": "blocked-antibot",
        "error": "bug-local"
      }
    }
  ]
}
